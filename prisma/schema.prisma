// This is your Prisma schema file, learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Prompt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  imageUrl       String   @map("image_url")
  corePrompt     String   @map("core_prompt")
  negativePrompt String   @default("") @map("negative_prompt")
  model          String
  category       String
  aspectRatio    String   @map("aspect_ratio")
  seed           BigInt?
  steps          Int?
  cfgScale       Decimal? @map("cfg_scale") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("prompts")
}

model AdminUser {
  id        String   @id @db.Uuid
  email     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("admin_users")
}
